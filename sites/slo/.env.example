# PostgreSQL Credentials
POSTGRESS_HOST=sgi_postgres
POSTGRES_DB=sgi_db
POSTGRES_USER=sgi_user
POSTGRES_PASSWORD=your_secure_password_here

# The base URL for your application
API_HOST=api.yourdomain.com

# Optional: JWT secret for protecting ancestors / descendants / match-detail
# endpoints. Must match JWT_AUTH_SECRET_KEY in the WordPress wp-config.php.
# Leave unset to keep the API fully public. See README §7.
# Single-quote the value so $, #, ` and spaces survive docker-compose parsing.
# JWT_SECRET='paste-the-exact-wp-config-secret-here'
